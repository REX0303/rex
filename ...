<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Dino Game</title>
<style>
    body {
        margin: 0;
        overflow: hidden;
        background: #fff;
    }
    canvas {
        display: block;
        margin: auto;
        background: #fff;
    }
</style>
</head>
<body>

<canvas id="gameCanvas" width="800" height="300"></canvas>

<script>
const canvas = document.getElementById("gameCanvas");
const ctx = canvas.getContext("2d");

// Dino
let dino = {
    x: 50,
    y: 200,
    width: 40,
    height: 40,
    velocity: 0,
    jumping: false
};

// Obstáculos
let obstacles = [];
let score = 0;
let gameOver = false;

// Gravedad
const gravity = 1;

// Crear obstáculo
function createObstacle() {
    obstacles.push({
        x: 800,
        y: 220,
        width: 20,
        height: 40
    });
}

// Loop del juego
function update() {
    if (gameOver) return;

    // Física del salto
    if (dino.jumping) {
        dino.velocity += gravity;
        dino.y += dino.velocity;

        if (dino.y >= 200) {
            dino.y = 200;
            dino.jumping = false;
            dino.velocity = 0;
        }
    }

    // Mover obstáculos
    obstacles.forEach((obs, index) => {
        obs.x -= 5;

        if (obs.x < -20) {
            obstacles.splice(index, 1);
            score++;
        }
    });

    // Generar obstáculos
    if (obstacles.length === 0 || obstacles[obstacles.length - 1].x < 500) {
        createObstacle();
    }

    // Colisiones
    obstacles.forEach(obs => {
        if (
            dino.x < obs.x + obs.width &&
            dino.x + dino.width > obs.x &&
            dino.y < obs.y + obs.height &&
            dino.y + dino.height > obs.y
        ) {
            gameOver = true;
        }
    });

    draw();
    requestAnimationFrame(update);
}

// Dibujar
function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    // Suelo
    ctx.fillStyle = "black";
    ctx.fillRect(0, 260, 800, 2);

    // Dino
    ctx.fillRect(dino.x, dino.y, dino.width, dino.height);

    // Obstáculos
    obstacles.forEach(obs => {
        ctx.fillRect(obs.x, obs.y, obs.width, obs.height);
    });

    // Score
    ctx.fillText("Score: " + score, 700, 20);

    if (gameOver) {
        ctx.fillText("GAME OVER", 350, 150);
    }
}

// Controles
document.addEventListener("keydown", function(e) {
    if (e.code === "Space" && !dino.jumping && !gameOver) {
        dino.jumping = true;
        dino.velocity = -15;
    }

    if (e.code === "Enter" && gameOver) {
        resetGame();
    }
});

// Reiniciar
function resetGame() {
    dino.y = 200;
    dino.velocity = 0;
    dino.jumping = false;
    obstacles = [];
    score = 0;
    gameOver = false;
    update();
}

// Iniciar
update();
</script>

</body>
</html>
